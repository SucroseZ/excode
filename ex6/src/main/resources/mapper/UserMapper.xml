<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.ex6.mapper.UserMapper">
    <select id="findAll" resultType="User">
        select * from tb_user;
    </select>

    <select id="findById" resultType="User" parameterType="Integer">
        select * from tb_user
        where id=#{id};
    </select>

    <select id="findByNameAndGender" resultType="User" parameterType="map">
        select * from tb_user
        where username = #{uname} and gender = #{ugender};
    </select>

    <insert id="addUser" parameterType="User" keyProperty="id" useGeneratedKeys="true">
        insert into tb_user (username, password,gender,addr) values(#{username},#{password},#{gender},#{addr})
    </insert>

    <update id="updateUserPassword">
        update tb_user set password = #{password} where id = #{id}
    </update>

    <!-- 删除一个用户 -->
    <delete id="deleteUser" parameterType="Integer">
        delete from tb_user where id = #{id}
    </delete>


</mapper>